VITE_API_URL=http://127.0.0.1:5000

# ── Backend (Flask / MySQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=rit_transport
